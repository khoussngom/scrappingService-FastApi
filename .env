# =============================================================================
# 🔧 VARIABLES D'ENVIRONNEMENT - SCRAPING-SERVICE
# =============================================================================

# -----------------------------------------------------------------------------
# CONFIGURATION APPLICATION
# -----------------------------------------------------------------------------
DEBUG=false
APP_NAME=scraping-service
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# RABBITMQ
# -----------------------------------------------------------------------------
RABBITMQ__HOST=rabbitmq
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=marakhib
RABBITMQ__PASSWORD=changeme
RABBITMQ__VHOST=/

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# -----------------------------------------------------------------------------
# SCRAPING CONFIGURATION
# -----------------------------------------------------------------------------
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_DELAY_BETWEEN_REQUESTS=2

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://marakhib-app.com
